---
import GalaxyVisualizer from '../components/GalaxyVisualizer';
---

<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Mekkode Aerospace | Simulador N-Body</title>
    <style>
        :root { color-scheme: dark; }
        *, *::before, *::after { box-sizing: border-box; }

        body, html {
            margin: 0; padding: 0; width: 100%; height: 100%;
            background-color: #000; color: white; overflow: hidden; 
            font-family: system-ui, -apple-system, sans-serif;
        }

        .sim-container { position: relative; width: 100%; height: 100%; background-color: #000; display: flex; flex-direction: column; }
        
        /* =========================================
           NUEVO: NAVBAR AEROESPACIAL 
        ========================================= */
        .top-navbar {
            position: relative; z-index: 20;
            background: rgba(15, 23, 42, 0.85);
            backdrop-filter: blur(10px); -webkit-backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(125, 211, 252, 0.2);
            padding: 0 20px; height: 50px;
            display: flex; align-items: center; justify-content: space-between;
            font-family: 'Courier New', Courier, monospace;
        }

        .nav-brand { font-weight: bold; color: #7dd3fc; font-size: 1.1rem; letter-spacing: 1px; }
        .nav-brand span { color: #facc15; }

        .nav-links { display: flex; gap: 20px; height: 100%; }
        .nav-link { 
            display: flex; align-items: center; color: #94a3b8; 
            text-decoration: none; font-size: 0.85rem; text-transform: uppercase;
            padding: 0 10px; border-bottom: 2px solid transparent; transition: all 0.2s;
        }
        .nav-link.active { color: #facc15; border-bottom: 2px solid #facc15; background: rgba(250, 204, 21, 0.05); }
        .nav-link:hover:not(.disabled) { color: white; border-bottom: 2px solid white; }
        .nav-link.disabled { opacity: 0.5; cursor: not-allowed; }

        /* Contenedores Principales */
        .workspace { flex: 1; position: relative; }
        .visualizer-container { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; }
        
        .ui-overlay { 
            position: absolute; top: 0; left: 0; width: 100%; height: 100%; 
            z-index: 10; pointer-events: none; padding: 20px; display: flex; 
            justify-content: space-between;
        }
        
        /* Panel Izquierdo: Controles */
        .controls-wrapper { display: flex; flex-direction: column; }
        header { margin-bottom: 1rem; text-shadow: 0 2px 10px rgba(0,0,0,0.8); }
        header h1 { font-size: 1.2rem; font-weight: 800; letter-spacing: 1px; color: #7dd3fc; margin: 0; }
        header p { font-size: 0.8rem; color: #a1a1aa; margin-top: 5px; }

        .sci-panel {
            background: rgba(15, 23, 42, 0.7);
            backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(125, 211, 252, 0.2); border-radius: 8px;
            padding: 20px; width: 320px; pointer-events: auto; 
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.5);
            max-height: calc(100vh - 120px); overflow-y: auto;
        }

        /* Panel Derecho: Telemetría */
        .telemetry-panel {
            background: rgba(0, 0, 0, 0.75);
            backdrop-filter: blur(8px); -webkit-backdrop-filter: blur(8px);
            border: 1px solid rgba(52, 211, 153, 0.3); border-radius: 8px;
            padding: 15px; width: 280px; pointer-events: auto;
            align-self: flex-start; font-family: 'Courier New', Courier, monospace;
        }
        .telemetry-panel h2 { font-size: 0.85rem; color: #34d399; margin-top: 0; margin-bottom: 1rem; border-bottom: 1px solid rgba(52, 211, 153, 0.3); padding-bottom: 5px; text-transform: uppercase; }
        .telemetry-group { margin-bottom: 1rem; }
        .telemetry-group h3 { font-size: 0.65rem; color: #94a3b8; text-transform: uppercase; margin-bottom: 4px; }
        .telemetry-row { display: flex; justify-content: space-between; font-size: 0.75rem; margin-bottom: 3px; color: #cbd5e1; }
        .telemetry-value { color: #facc15; font-weight: bold; }
        .telemetry-value.green { color: #34d399; }
        .telemetry-value.blue { color: #38bdf8; }

        /* Componentes de UI internos */
        .sci-panel::-webkit-scrollbar { width: 4px; }
        .sci-panel::-webkit-scrollbar-thumb { background: rgba(125, 211, 252, 0.3); border-radius: 2px; }
        .data-block { margin-bottom: 1.2rem; }
        .control-block { margin-top: 1.2rem; padding-top: 1rem; border-top: 1px dashed rgba(125, 211, 252, 0.3); }
        .slider-container { display: flex; flex-direction: column; gap: 6px; margin-bottom: 12px; }
        .slider-container label { font-size: 0.8rem; color: #e0e7ff; display: flex; justify-content: space-between; }
        .slider-container span { color: #facc15; font-weight: bold; font-family: 'Courier New', monospace; }
        
        /* =========================================
           FIX CSS: BARRITAS DE GRAVEDAD / TIEMPO 
        ========================================= */
        input[type=range] { 
            -webkit-appearance: none; appearance: none; 
            width: 100%; background: transparent; margin: 8px 0; 
        }
        input[type=range]:focus { outline: none; }
        /* Pista del slider garantizada visible */
        input[type=range]::-webkit-slider-runnable-track { 
            width: 100%; height: 4px; cursor: pointer; 
            background: #475569; /* Gris pizarra sólido para contraste */
            border-radius: 2px; border: 1px solid #1e293b;
        }
        /* Botón (Thumb) del slider */
        input[type=range]::-webkit-slider-thumb { 
            -webkit-appearance: none; appearance: none; 
            height: 14px; width: 14px; border-radius: 50%; 
            background: #facc15; cursor: pointer; 
            margin-top: -6px; /* Centrado vertical matemático */
            box-shadow: 0 0 8px rgba(250, 204, 21, 0.8); 
        }
        /* Fix equivalente para Mozilla Firefox */
        input[type=range]::-moz-range-track { 
            width: 100%; height: 4px; cursor: pointer; 
            background: #475569; border-radius: 2px; 
        }
        input[type=range]::-moz-range-thumb { 
            height: 14px; width: 14px; border-radius: 50%; 
            background: #facc15; cursor: pointer; border: none; 
            box-shadow: 0 0 8px rgba(250, 204, 21, 0.8); 
        }

        .toggle-container { display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; font-size: 0.8rem; color: #e0e7ff;}
        input[type=checkbox] { accent-color: #facc15; width: 16px; height: 16px; cursor: pointer; }
        .select-container { display: flex; flex-direction: column; gap: 4px; margin-bottom: 12px; font-size: 0.8rem; color: #e0e7ff; }
        select { background: rgba(15, 23, 42, 0.9); color: #facc15; border: 1px solid rgba(125, 211, 252, 0.4); padding: 6px; border-radius: 4px; outline: none; font-weight: bold; cursor: pointer; font-size: 0.8rem;}
        .btn-action { width: 100%; padding: 10px; margin-top: 8px; font-weight: bold; border-radius: 4px; cursor: pointer; transition: all 0.2s; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 1px; border: none; }
        .btn-pause { background: rgba(250, 204, 21, 0.2); border: 1px solid rgba(250, 204, 21, 0.5); color: #fef08a; }
        .btn-pause:hover { background: rgba(250, 204, 21, 0.4); color: white; }
        .btn-reset { background: rgba(239, 68, 68, 0.2); border: 1px solid rgba(239, 68, 68, 0.5); color: #fca5a5; }
        .btn-reset:hover { background: rgba(239, 68, 68, 0.4); color: white; }
    </style>
</head>
<body>
    <main class="sim-container">
        
        <nav class="top-navbar">
            <div class="nav-brand">Mekkode<span>_</span>Aerospace</div>
            <div class="nav-links">
                <a href="#" class="nav-link active">Astrofísica N-Body</a>
                <a href="#" class="nav-link disabled" title="Próximamente">Órbitas (Satélites) 🔒</a>
                <a href="#" class="nav-link disabled" title="Próximamente">Dinámica Cohetes 🔒</a>
            </div>
        </nav>

        <div class="workspace">
            <div class="ui-overlay">
                <div class="controls-wrapper">
                    <header>
                        <h1>Laboratorio Computacional</h1>
                        <p>GPU Compute | Tiempo Real</p>
                    </header>
                    
                    <aside class="sci-panel">
                        <div class="data-block">
                            <div class="select-container">
                                <label style="color: #7dd3fc; margin-bottom: 5px;">RÉGIMEN FÍSICO:</label>
                                <select id="simMode" class="highlight-select" style="border-color: #facc15; background: rgba(250, 204, 21, 0.1);">
                                    <option value="galaxy">Mecánica Clásica (Colisión)</option>
                                    <option value="blackhole">Métrica de Schwarzschild</option>
                                </select>
                            </div>
                        </div>

                        <div class="data-block control-block" style="margin-top: 0; border-top: none;">
                            <div class="select-container">
                                <label>Núcleo Primario:</label>
                                <select id="typeGal1">
                                    <option value="spiral">Disco Espiral</option>
                                    <option value="elliptical">Enjambre Elíptico</option>
                                </select>
                            </div>
                            <div class="select-container">
                                <label>Núcleo Secundario:</label>
                                <select id="typeGal2">
                                    <option value="spiral">Disco Espiral</option>
                                    <option value="elliptical">Enjambre Elíptico</option>
                                    <option value="dwarf">Satélite Enano</option>
                                </select>
                            </div>
                        </div>

                        <div class="data-block control-block">
                            <div class="toggle-container">
                                <label title="Efecto de acercamiento estelar">Relativistic Beaming</label>
                                <input type="checkbox" id="dopplerToggle" checked />
                            </div>

                            <div class="slider-container">
                                <label>Gravedad (G): <span id="gravityValueDisplay">0.15</span></label>
                                <input type="range" id="gravitySlider" min="0.0" max="0.5" step="0.01" value="0.15" />
                            </div>

                            <div class="slider-container">
                                <label>Integración (Δt): <span id="timeValueDisplay">0.016</span></label>
                                <input type="range" id="timeSlider" min="0.001" max="0.050" step="0.001" value="0.016" />
                            </div>
                        </div>

                        <div class="data-block control-block">
                            <button id="pauseButton" class="btn-action btn-pause">Pausar Simulación</button>
                            <button id="resetButton" class="btn-action btn-reset">Compilar Escenario</button>
                        </div>
                    </aside>
                </div>

                <aside class="telemetry-panel">
                    <h2>Telemetría GPU</h2>
                    <div class="telemetry-group">
                        <h3>Carga de Cómputo</h3>
                        <div class="telemetry-row"><span>Frame Rate:</span> <span id="hud-fps" class="telemetry-value green">60 FPS</span></div>
                        <div class="telemetry-row"><span>Entidades:</span> <span class="telemetry-value">65,536</span></div>
                        <div class="telemetry-row"><span>Operaciones:</span> <span id="hud-flops" class="telemetry-value blue">-- GFLOPs</span></div>
                    </div>
                    <div class="telemetry-group">
                        <h3>Métrica Espacial</h3>
                        <div class="telemetry-row"><span>Masa (M):</span> <span id="hud-mass" class="telemetry-value">--</span></div>
                        <div class="telemetry-row"><span>Schwarzschild (Rs):</span> <span id="hud-rs" class="telemetry-value">--</span></div>
                        <div class="telemetry-row"><span>Fotones (1.5 Rs):</span> <span id="hud-photon" class="telemetry-value">--</span></div>
                        <div class="telemetry-row"><span>ISCO (3.0 Rs):</span> <span id="hud-isco" class="telemetry-value">--</span></div>
                    </div>
                    <div class="telemetry-group">
                        <h3>Distorsión Relativista</h3>
                        <div class="telemetry-row"><span>Lente Gravitacional:</span> <span id="hud-ray-steps" class="telemetry-value">Inactiva</span></div>
                        <div class="telemetry-row"><span>Dilatación (Δt):</span> <span id="hud-dilation" class="telemetry-value">--</span></div>
                    </div>
                </aside>
            </div>

            <div class="visualizer-container">
                <GalaxyVisualizer client:only="react" />
            </div>
        </div>
    </main>
</body>
</html>