---
import GalaxyVisualizer from '../components/GalaxyVisualizer';
---

<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Laboratorio Astrofísico N-Body</title>
    <style>
        :root { color-scheme: dark; }
        *, *::before, *::after { box-sizing: border-box; }

        body, html {
            margin: 0; padding: 0; width: 100%; height: 100%;
            background-color: #000; color: white; overflow: hidden; 
            font-family: system-ui, -apple-system, sans-serif;
        }

        .sim-container { position: relative; width: 100%; height: 100%; background-color: #000; }
        .visualizer-container { position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; }
        
        .ui-overlay { 
            position: absolute; top: 0; left: 0; width: 100%; height: 100%; 
            z-index: 10; pointer-events: none; padding: 30px; display: flex; flex-direction: column;
        }
        
        header { margin-bottom: 2rem; text-shadow: 0 2px 10px rgba(0,0,0,0.8); }
        header h1 { font-size: 1.5rem; font-weight: 800; letter-spacing: 1px; color: #7dd3fc; margin: 0; }
        header p { font-size: 0.9rem; color: #a1a1aa; margin-top: 5px; }

        .sci-panel {
            align-self: flex-start; background: rgba(15, 23, 42, 0.6);
            backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(125, 211, 252, 0.2); border-radius: 12px;
            padding: 24px; width: 340px; pointer-events: auto; 
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.8);
            max-height: calc(100vh - 120px); overflow-y: auto;
        }

        .sci-panel::-webkit-scrollbar { width: 6px; }
        .sci-panel::-webkit-scrollbar-thumb { background: rgba(125, 211, 252, 0.3); border-radius: 3px; }

        .sci-panel h2 { font-size: 1rem; color: #7dd3fc; margin-top: 0; margin-bottom: 1.5rem; text-align: center; border-bottom: 1px solid rgba(125, 211, 252, 0.2); padding-bottom: 12px; }

        .data-block { margin-bottom: 1.5rem; }
        .data-block h3 { font-size: 0.8rem; color: #94a3b8; font-weight: 600; text-transform: uppercase; margin-bottom: 0.8rem; }
        
        .control-block { margin-top: 1.5rem; padding-top: 1rem; border-top: 1px dashed rgba(125, 211, 252, 0.3); }
        .slider-container { display: flex; flex-direction: column; gap: 8px; margin-bottom: 15px; }
        .slider-container label { font-size: 0.85rem; color: #e0e7ff; display: flex; justify-content: space-between; }
        .slider-container span { color: #facc15; font-weight: bold; font-family: 'Courier New', monospace; }
        
        input[type=range] { -webkit-appearance: none; appearance: none; width: 100%; background: transparent; margin: 5px 0; }
        input[type=range]:focus { outline: none; }
        input[type=range]::-webkit-slider-runnable-track { width: 100%; height: 6px; cursor: pointer; background: rgba(125, 211, 252, 0.3); border-radius: 4px; }
        input[type=range]::-webkit-slider-thumb { -webkit-appearance: none; appearance: none; height: 16px; width: 16px; border-radius: 50%; background: #facc15; cursor: pointer; margin-top: -5px; box-shadow: 0 0 10px rgba(250, 204, 21, 0.6); }
        input[type=range]::-moz-range-track { width: 100%; height: 6px; cursor: pointer; background: rgba(125, 211, 252, 0.3); border-radius: 4px; }
        input[type=range]::-moz-range-thumb { height: 16px; width: 16px; border-radius: 50%; background: #facc15; cursor: pointer; border: none; box-shadow: 0 0 10px rgba(250, 204, 21, 0.6); }

        .toggle-container { display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px; font-size: 0.85rem; color: #e0e7ff;}
        input[type=checkbox] { accent-color: #facc15; width: 18px; height: 18px; cursor: pointer; }

        .select-container { display: flex; flex-direction: column; gap: 5px; margin-bottom: 15px; font-size: 0.85rem; color: #e0e7ff; }
        select { background: rgba(15, 23, 42, 0.8); color: #facc15; border: 1px solid rgba(125, 211, 252, 0.3); padding: 8px; border-radius: 4px; outline: none; font-weight: bold; cursor: pointer; }
        
        .highlight-select { border-color: #facc15; background: rgba(250, 204, 21, 0.1); }

        .btn-action {
            width: 100%; padding: 12px; margin-top: 10px;
            font-weight: bold; border-radius: 6px; cursor: pointer;
            transition: all 0.2s; text-transform: uppercase; font-size: 0.8rem; letter-spacing: 1px; border: none;
        }
        .btn-pause { background: rgba(250, 204, 21, 0.2); border: 1px solid rgba(250, 204, 21, 0.5); color: #fef08a; }
        .btn-pause:hover { background: rgba(250, 204, 21, 0.4); box-shadow: 0 0 15px rgba(250, 204, 21, 0.4); color: white; }
        
        .btn-reset { background: rgba(239, 68, 68, 0.2); border: 1px solid rgba(239, 68, 68, 0.5); color: #fca5a5; }
        .btn-reset:hover { background: rgba(239, 68, 68, 0.4); box-shadow: 0 0 15px rgba(239, 68, 68, 0.4); color: white; }
        .btn-action:active { transform: scale(0.98); }
    </style>
</head>
<body>
    <main class="sim-container">
        <div class="ui-overlay">
            <header>
                <h1>Laboratorio N-Body</h1>
                <p>Simulación GPU en Tiempo Real</p>
            </header>
            
            <aside class="sci-panel">
                <h2>Terminal de Control</h2>

                <div class="data-block">
                    <div class="select-container">
                        <label style="color: #7dd3fc; margin-bottom: 5px;">MODO DE SIMULACIÓN:</label>
                        <select id="simMode" class="highlight-select">
                            <option value="galaxy">🌌 Choque Galáctico (Gas y Polvo)</option>
                            <option value="blackhole">🕳️ Agujero Negro Devorador</option>
                        </select>
                    </div>
                </div>

                <div class="data-block control-block" style="margin-top: 0; border-top: none;">
                    <h3>Morfología de Galaxias</h3>
                    <div class="select-container">
                        <label>Galaxia Primaria:</label>
                        <select id="typeGal1">
                            <option value="spiral">Espiral (Vía Láctea)</option>
                            <option value="elliptical">Elíptica (Caótica)</option>
                        </select>
                    </div>
                    <div class="select-container">
                        <label>Galaxia Secundaria:</label>
                        <select id="typeGal2">
                            <option value="spiral">Espiral</option>
                            <option value="elliptical">Elíptica</option>
                            <option value="dwarf">Enana (Satélite)</option>
                        </select>
                    </div>
                </div>

                <div class="data-block control-block">
                    <h3>Física e Iluminación</h3>
                    
                    <div class="toggle-container">
                        <label title="Estrellas azules si se acercan, rojas si se alejan">Efecto Doppler Espacial</label>
                        <input type="checkbox" id="dopplerToggle" checked />
                    </div>

                    <div class="slider-container">
                        <label>Gravedad Base (G): <span id="gravityValueDisplay">0.15</span></label>
                        <input type="range" id="gravitySlider" min="0.0" max="0.5" step="0.01" value="0.15" />
                    </div>

                    <div class="slider-container">
                        <label>Velocidad Tiempo (dt): <span id="timeValueDisplay">0.016</span></label>
                        <input type="range" id="timeSlider" min="0.001" max="0.050" step="0.001" value="0.016" />
                    </div>
                </div>

                <div class="data-block control-block">
                    <button id="pauseButton" class="btn-action btn-pause">Pausar Simulación</button>
                    <button id="resetButton" class="btn-action btn-reset">Reiniciar / Aplicar Cambios</button>
                </div>
            </aside>
        </div>

        <div class="visualizer-container">
            <GalaxyVisualizer client:only="react" />
        </div>
    </main>
</body>
</html>